<script>
  let count = 0;
  
  function increment() {
    count++;
  }
</script>

<template>
  <div class="card">
    <h1>Welcome to FluxDOM 🌊</h1>
    <p>Adaptive Rendering Framework</p>
    <button @click="increment">
      Count is: {count}
    </button>
  </div>
</template>

