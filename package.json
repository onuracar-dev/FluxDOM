{
  "name": "FluxDOM-monorepo",
  "version": "0.1.0",
  "description": "Experimental .flow component compiler and fine-grained DOM runtime.",
  "private": true,
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "scripts": {
    "build": "tsc -b --force && npm run build --workspace docs && npm run build --workspace hello-world",
    "dev": "npm run dev --workspaces",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,md,html,css}\"",
    "publish-all": "npm publish --workspaces --access public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jsdom": "^24.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.10"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ]
}
